# ---------------------------------------------------------------------------
# ProxView core
# ---------------------------------------------------------------------------
# Host port the dashboard is published on.
PORT=8080

# Host interface the port is published on. Defaults to 127.0.0.1 (localhost only).
# On a VPS/remote host, set this to your WireGuard/Tailscale interface IP so the
# dashboard is reachable over the private tunnel but NOT the public internet —
# e.g. BIND_ADDR=10.0.0.7 . Do not use 0.0.0.0 on a public box.
BIND_ADDR=127.0.0.1

# Set to 1 to run with synthetic demo data — explore the whole UI without a
# real Proxmox cluster. Leave 0 for production.
DEMO=0

# 64 hex chars (32 bytes) used to encrypt stored Proxmox/PBS credentials at rest.
# Generate one with:  openssl rand -hex 32
# Leave blank to auto-generate ./data/secret.key on first run (BACK IT UP — losing
# it means re-entering every site's API token).
PROXVIEW_SECRET_KEY=

# Optional: provision the admin account on first boot instead of the log-printed
# setup token — handy for scripted/unattended deploys. If PROXVIEW_ADMIN_PASSWORD
# is set (min 8 chars), ProxView creates this user and you can log in immediately.
PROXVIEW_ADMIN_USER=admin
PROXVIEW_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Optional plugin: Caddy reverse proxy  (friendly LAN URL, no port number)
#   docker compose -f docker-compose.yml -f docker-compose.caddy.yml up -d
# ---------------------------------------------------------------------------
PROXVIEW_HOSTNAME=proxview.home
# Interface Caddy publishes :80/:443 on. 0.0.0.0 for a LAN box; on a public VPS
# set a private/tunnel IP instead.
CADDY_BIND=0.0.0.0

# ---------------------------------------------------------------------------
# Optional plugin: Cloudflare Tunnel  (public HTTPS, no open ports)
#   docker compose --profile cloudflare up -d
# ---------------------------------------------------------------------------
CF_TUNNEL_TOKEN=

# ---------------------------------------------------------------------------
# Optional plugin: Tailscale Serve  (tailnet-only HTTPS)
#   docker compose -f docker-compose.yml -f docker-compose.tailscale.yml up -d
# ---------------------------------------------------------------------------
TS_AUTHKEY=
